rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow anyone to create an order (required for landing page checkout)
    match /orders/{orderId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null && request.auth.token.email == "ibotshopline@gmail.com";
    }
    
    // CRM stats and metadata
    match /settings/{docId} {
      allow read, write: if request.auth != null && request.auth.token.email == "ibotshopline@gmail.com";
    }
  }
}
